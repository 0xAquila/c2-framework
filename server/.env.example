# C2 Framework — Required Environment Variables
# Copy this file to .env and fill in values, or run:
#   python setup_secrets.py
#
# All variables are REQUIRED. The server will not start without them.
# No default values are used — every secret must be explicitly set.

# Beacon token: agents must include this in X-Beacon-Token header to reach beacon endpoints.
# All agents share this for initial registration; per-agent tokens replace it post-ECDH.
C2_API_KEY=<generate: python -c "import os; print(os.urandom(32).hex())">

# Flask session signing key. Must be random and kept secret.
SECRET_KEY=<generate: python -c "import os; print(os.urandom(32).hex())">

# Operator gateway header. Operator's browser must send X-Operator-Key: <value> to reach /login.
# Injected automatically via Burp Suite Match & Replace rule.
OPERATOR_KEY=<generate: python -c "import os; print(os.urandom(32).hex())">

# Operator dashboard credentials
OPERATOR_USER=operator
OPERATOR_PASS=<generate: python -c "import secrets; print(secrets.token_urlsafe(24))">

# Bootstrap AES-256 key (64-char hex = 32 bytes). Used to encrypt the initial ECDH registration
# handshake. After registration, each agent uses its own HKDF-derived session key.
# Must be the same value embedded in agent/config.py or generated agents.
ENCRYPTION_KEY=<generate: python -c "import os; print(os.urandom(32).hex())">

# Separate key for encrypting sensitive fields in SQLite at rest (hostname, ip, username,
# commands, results). Keep distinct from ENCRYPTION_KEY so they can be rotated independently.
DB_ENCRYPTION_KEY=<generate: python -c "import os; print(os.urandom(32).hex())">

# Set to "false" to disable AES encryption on beacon channel (for debugging only)
ENCRYPT_BEACON=true
